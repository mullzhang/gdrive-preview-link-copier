{
  "manifest_version": 3,
  "name": "Drive Preview Link Copier",
  "version": "0.1.0",
  "description": "Google Docs/Sheets/Slides linksをDrive preview URLに変換してコピーします",
  "permissions": [
    "contextMenus",
    "activeTab",
    "scripting",
    "offscreen",
    "clipboardWrite",
    "clipboardRead"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "https://drive.google.com/*",
        "https://docs.google.com/*"
      ],
      "js": [
        "drive-content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "プレビューリンクをコピー",
    "default_popup": "popup.html"
  },
  "commands": {
    "convert_clipboard_to_preview": {
      "description": "クリップボードのリンクをプレビューリンクに変換",
      "suggested_key": {
        "default": "Ctrl+Shift+Y",
        "mac": "Command+Shift+Y"
      }
    }
  }
}
